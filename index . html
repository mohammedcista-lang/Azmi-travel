<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>عزمي للسفر والسياحة</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    direction: rtl;
    background: #0a0a0a;
    color: white;
}

/* هيدر فاخر */
header {
    position: fixed;
    width: 100%;
    background: rgba(0,0,0,0.8);
    padding: 15px;
    text-align: center;
    z-index: 1000;
}

/* هيرو */
.hero {
    height: 100vh;
    background: linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
    url('https://images.unsplash.com/photo-1502920917128-1aa500764b6b');
    background-size: cover;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
}

.hero h1 {
    font-size: 45px;
}

/* الفورم */
.booking {
    background: white;
    color: black;
    padding: 20px;
    border-radius: 15px;
    width: 90%;
    max-width: 400px;
    margin: -100px auto 50px;
}

.booking input {
    width: 100%;
    padding: 10px;
    margin: 8px 0;
}

/* زر */
button {
    width: 100%;
    padding: 12px;
    background: gold;
    border: none;
    font-weight: bold;
    cursor: pointer;
}

/* العروض */
.section {
    padding: 40px;
    text-align: center;
}

.card {
    background: #1a1a1a;
    margin: 10px;
    padding: 20px;
    border-radius: 10px;
}

/* واتساب */
.whatsapp {
    position: fixed;
    bottom: 20px;
    left: 20px;
    background: #25D366;
    padding: 15px;
    border-radius: 50%;
    text-decoration: none;
    color: white;
}
</style>
</head>

<body>

<header>
    <h2>عزمي للسفر والسياحة ✈️</h2>
</header>

<div class="hero">
    <div>
        <h1>احجز رحلتك الآن</h1>
        <p>أفضل الأسعار - خدمة موثوقة</p>
    </div>
</div>

<!-- فورم الحجز -->
<div class="booking">
    <h3>احجز رحلتك</h3>

    <input type="text" id="name" placeholder="اسمك">
    <input type="text" id="from" placeholder="من">
    <input type="text" id="to" placeholder="إلى">
    <input type="date" id="date">

    <button onclick="sendWhatsApp()">احجز الآن</button>
</div>

<!-- العروض -->
<div class="section">
    <h2>العروض</h2>

    <div class="card">
        جدة ✈️ بورتسودان - 980,000
    </div>

    <div class="card">
        بورتسودان ✈️ جدة - 830,000
    </div>
</div>

<!-- زر واتساب -->
<a class="whatsapp" href="https://wa.me/249125561790" target="_blank">💬</a>

<script>
function sendWhatsApp() {
    var name = document.getElementById("name").value;
    var from = document.getElementById("from").value;
    var to = document.getElementById("to").value;
    var date = document.getElementById("date").value;

    var message = `حجز جديد:%0Aالاسم: ${name}%0Aمن: ${from}%0Aإلى: ${to}%0Aالتاريخ: ${date}`;

    window.open("https://wa.me/249125561790?text=" + message);
}
</script>

</body>
</html>